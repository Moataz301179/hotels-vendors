// ─────────────────────────────────────────
// COASTAL DIFFERENTIATION MODELS
// ─────────────────────────────────────────

enum CreditFacilityStatus {
  PENDING
  ACTIVE
  REJECTED
  EXPIRED
}

model CreditFacility {
  id                 String               @id @default(cuid())
  hotelId            String
  hotel              Hotel                @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  factoringCompanyId String
  factoringCompany   FactoringCompany     @relation(fields: [factoringCompanyId], references: [id], onDelete: Cascade)
  limit              Float
  utilized           Float                @default(0)
  interestRate       Float
  status             CreditFacilityStatus @default(PENDING)
  approvedAt         DateTime?
  expiresAt          DateTime?

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ConsolidatedOrder {
  id           String       @id @default(cuid())
  hubId        String
  hub          LogisticsHub @relation(fields: [hubId], references: [id], onDelete: Cascade)
  tripId       String?
  trip         Trip?        @relation(fields: [tripId], references: [id])
  status       String       @default("PENDING")
  totalValue   Float        @default(0)
  deliveryDate DateTime?

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
